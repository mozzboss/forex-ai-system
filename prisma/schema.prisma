// ============================================================
// FOREX AI SYSTEM - DATABASE SCHEMA
// ============================================================

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountMode {
  funded
  personal
}

enum TradeDirection {
  LONG
  SHORT
}

enum SetupType {
  pullback
  breakout
  reversal
  liquidity_sweep
}

enum TradeStatus {
  pending
  open
  closed
  cancelled
  denied
}

enum EntryStatus {
  WAIT
  READY
  CONFIRMED
  INVALID
}

enum JournalEntryType {
  trade
  review
  lesson
  plan
}

enum NewsImpact {
  low
  medium
  high
}

model User {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email          String   @unique
  name           String?
  trackedPairs   String[] @default(["EURUSD", "GBPUSD", "USDJPY", "USDCHF", "AUDUSD", "NZDUSD", "USDCAD", "XAUUSD"])
  telegramChatId String?  @unique
  telegramLinkCode String? @unique
  telegramLinkCodeExpiresAt DateTime?
  telegramAlertsEnabled Boolean @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  accounts     TradingAccount[]
  trades       Trade[]
  journal      JournalEntry[]
  dailyPlans   DailyPlan[]
  analysisLogs AnalysisLog[]
}

model TradingAccount {
  id                 String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String      @db.Uuid
  name               String
  mode               AccountMode
  balance            Decimal     @db.Decimal(18, 4)
  equity             Decimal     @db.Decimal(18, 4)
  riskPercent        Decimal     @db.Decimal(6, 4)
  maxDailyLoss       Decimal     @db.Decimal(18, 4)
  maxDrawdown        Decimal     @db.Decimal(18, 4)
  maxTradesPerDay    Int
  currentDailyLoss   Decimal     @default(0) @db.Decimal(18, 4)
  currentDailyTrades Int         @default(0)
  lossesInARow       Int         @default(0)
  isActive           Boolean     @default(true)
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades Trade[]

  @@index([userId])
  @@index([userId, isActive])
}

model Trade {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  accountId       String         @db.Uuid
  userId          String         @db.Uuid
  externalRef     String?        @unique
  pair            String
  direction       TradeDirection
  setupType       SetupType
  entryPrice      Decimal        @db.Decimal(18, 6)
  stopLoss        Decimal        @db.Decimal(18, 6)
  takeProfit      Decimal        @db.Decimal(18, 6)
  lotSize         Decimal        @db.Decimal(12, 4)
  riskAmount      Decimal        @db.Decimal(18, 4)
  riskRewardRatio Decimal        @db.Decimal(10, 4)
  status          TradeStatus
  entryStatus     EntryStatus
  pnl             Decimal?       @db.Decimal(18, 4)
  pipsPnl         Decimal?       @db.Decimal(18, 4)
  aiScore         Int
  aiDecision      String
  aiReasoning     String
  denialReason    String?
  notes           String?
  openedAt        DateTime?
  closedAt        DateTime?
  createdAt       DateTime       @default(now())

  account        TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  journalEntries JournalEntry[]

  @@index([accountId])
  @@index([userId])
  @@index([pair])
  @@index([status])
  @@index([accountId, status])
  @@index([userId, createdAt])
}

model JournalEntry {
  id              String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String           @db.Uuid
  tradeId         String?          @db.Uuid
  date            DateTime
  type            JournalEntryType
  content         String
  mistakes        String[]         @default([])
  disciplineScore Int?
  aiFeedback      String?
  tags            String[]         @default([])
  createdAt       DateTime         @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  trade Trade? @relation(fields: [tradeId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([tradeId])
  @@index([date])
  @@index([userId, date])
}

model DailyPlan {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @db.Uuid
  date            DateTime
  pairs           String[]
  macroBias       String
  keyLevels       String
  newsEvents      String
  sessionFocus    String
  maxTrades       Int
  planNotes       String?
  reviewNotes     String?
  disciplineScore Int?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
}

model NewsEvent {
  id        String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  time      DateTime
  currency  String
  event     String
  impact    NewsImpact
  forecast  String?
  previous  String?
  actual    String?
  fetchedAt DateTime   @default(now())

  @@index([time])
  @@index([currency])
  @@index([impact])
}

model AnalysisCache {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pair      String
  analysis  String
  createdAt DateTime @default(now())
  expiresAt DateTime

  @@index([pair])
  @@index([expiresAt])
}

model AnalysisLog {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  pair      String
  result    String   // JSON-serialized FullAnalysis
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, pair])
  @@index([userId, createdAt])
}
