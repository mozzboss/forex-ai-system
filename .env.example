# ============================================================
# FOREX AI SYSTEM — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# --- Database (required) ---
# Supabase project → Settings → Database → Connection string
# DATABASE_URL: use the connection pooler (port 6543) for serverless/Next.js API routes.
# DIRECT_URL: use the direct connection (port 5432) for Prisma migrations (prisma db push / migrate).
# IMPORTANT: Do NOT append ?pgbouncer=true here — Vercel URL-encodes it, causing a
# "database postgres=true does not exist" error. It is injected automatically by src/lib/prisma.ts.
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres
DIRECT_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# --- Supabase (required) ---
# Found in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Anthropic Claude (required) ---
# Found at console.anthropic.com → API Keys
# Used by the AI analysis engine and daily plan / end-of-day review generators.
ANTHROPIC_API_KEY=sk-ant-your-key

# --- Telegram bot (optional) ---
# Create a bot via @BotFather on Telegram, then copy the token here.
# Without this, Telegram alerts and bot commands are silently disabled.
# Webhook endpoint: POST /api/telegram
TELEGRAM_BOT_TOKEN=your-bot-token
# Optional: set a random secret and pass it as &secret_token= when calling setWebhook.
# The webhook handler will reject requests that don't include this header.
TELEGRAM_WEBHOOK_SECRET=

# --- Market data — TwelveData (optional) ---
# Sign up at twelvedata.com. Without this, market snapshots use static
# fallback data. Fallback is clearly labelled in the UI and AI context.
TWELVE_DATA_API_KEY=your-twelvedata-key

# --- Economic calendar — Financial Modeling Prep (recommended) ---
# Sign up at financialmodelingprep.com and create an API key.
# The app uses this as the primary economic calendar provider.
FMP_API_KEY=your-fmp-key

# --- Economic calendar backup — TradingEconomics (optional) ---
# Used only if FMP is unavailable or returns no events.
# Sign up at tradingeconomics.com/api (guest:guest works for light dev usage).
TRADING_ECONOMICS_API_KEY=guest:guest

# --- App (optional) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
