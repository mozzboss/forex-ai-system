# ============================================================
# FOREX AI SYSTEM — ENVIRONMENT VARIABLES
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to version control.
# ============================================================

# --- Database (required) ---
# Supabase project → Settings → Database → Connection string
# DATABASE_URL: use the connection pooler (port 6543) for serverless/Next.js API routes.
# DIRECT_URL: use the direct connection (port 5432) for Prisma migrations (prisma db push / migrate).
DATABASE_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres.your-project-ref:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# --- Supabase (required) ---
# Found in your Supabase project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Anthropic Claude (required) ---
# Found at console.anthropic.com → API Keys
# Used by the AI analysis engine and daily plan / end-of-day review generators.
ANTHROPIC_API_KEY=sk-ant-your-key

# --- Telegram bot (optional) ---
# Create a bot via @BotFather on Telegram, then copy the token here.
# Without this, Telegram alerts and bot commands are silently disabled.
# Webhook endpoint: POST /api/telegram
TELEGRAM_BOT_TOKEN=your-bot-token
# Optional: set a random secret and pass it as &secret_token= when calling setWebhook.
# The webhook handler will reject requests that don't include this header.
TELEGRAM_WEBHOOK_SECRET=

# --- Market data — TwelveData (optional) ---
# Sign up at twelvedata.com. Without this, market snapshots use static
# fallback data. Fallback is clearly labelled in the UI and AI context.
TWELVE_DATA_API_KEY=your-twelvedata-key

# --- Economic calendar — TradingEconomics (optional) ---
# Sign up at tradingeconomics.com/api.
# Without this the news feed uses a static fallback event list.
# Guest access (guest:guest) works for low-volume local dev.
TRADING_ECONOMICS_API_KEY=guest:guest

# --- App (optional) ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local single-user fallback for API auth (optional)
# Leave unset in production. When true, missing bearer tokens map to the seeded default user.
ALLOW_DEFAULT_USER_FALLBACK=false

# --- Cron alerts (optional, recommended for offline alerts) ---
# Vercel Cron calls /api/cron/trade-alerts with Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=replace-with-long-random-secret
# Comma-separated scan list used when no daily plan pairs are saved.
TRADE_ALERT_SCAN_PAIRS=EURUSD,GBPUSD,USDJPY
# Max pairs checked per user each cron cycle.
TRADE_ALERT_MAX_PAIRS_PER_USER=3
# Minimum score for sending a trade-now alert.
TRADE_ALERT_MIN_SCORE=8
# Restrict alerts by session (comma-separated: london,new_york,asia,overlap_lon_ny).
TRADE_ALERT_ALLOWED_SESSIONS=london,new_york,overlap_lon_ny
# Cooldown per user+pair for repeated trade-now alerts.
TRADE_ALERT_COOLDOWN_MINUTES=120
# Heartbeat frequency per user to confirm scanner health.
TRADE_ALERT_HEARTBEAT_HOURS=24
# Cooldown for operations failure notifications.
TRADE_ALERT_FAILURE_COOLDOWN_MINUTES=30
# Optional operations inbox for scanner failure notifications.
TRADE_ALERT_OPERATIONS_EMAIL=ops@example.com

# --- Email fallback channel (optional) ---
# Used when Telegram delivery fails or is unavailable.
RESEND_API_KEY=re_xxx
ALERT_FROM_EMAIL=Forex AI Alerts <alerts@example.com>
